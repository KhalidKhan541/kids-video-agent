# Kids Video Agent - Environment Configuration
# =============================================
# Copy this file to .env and fill in your values

# --- Groq API (Free tier: 30 RPM) ---
# Get your API key: https://console.groq.com
GROQ_API_KEY=your-groq-key-here

# --- Pixabay API (Free: 5,000 requests/day) ---
# Get your API key: https://pixabay.com/api/docs/
PIXABAY_API_KEY=your-pixabay-key-here

# --- Pollinations.ai (free, no key needed) ---
POLLINATIONS_WATERMARK=kids-video-agent

# --- Piper TTS (local, no key needed) ---
PIPER_VOICE=en_US-amy-medium

# --- YouTube API (Google Cloud Console) ---
# Get credentials: https://console.cloud.google.com
YOUTUBE_CLIENT_ID=your-client-id
YOUTUBE_CLIENT_SECRET=your-client-secret
YOUTUBE_REFRESH_TOKEN=your-refresh-token
YOUTUBE_CHANNEL_ID=your-channel-id

# --- Email Notifications (Google SMTP) ---
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your-email@gmail.com
SMTP_APP_PASSWORD=your-16-char-app-password
NOTIFY_EMAIL=your-email@gmail.com

# --- GitHub ---
GITHUB_TOKEN=your-github-token

# --- Channels ---
DEFAULT_LANGUAGE=en
DEFAULT_CHANNEL_NAME=Kids Wonderland
UPLOAD_SCHEDULE=weekly
